{
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/dashboard.html",
      "destination": "/public/dashboard.html"
    },
    {
      "source": "/login.html",
      "destination": "/public/login.html"
    },
    {
      "source": "/successpayment.html",
      "destination": "/public/successpayment.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": ":subdomain.lancar.my"
        }
      ],
      "destination": "/api/serve-subdomain"
    }
  ]
}
